{
    "preset": "laravel",
    "rules": {
        "simplified_null_return": true,
        "braces": false,
        "new_with_parentheses": {
            "anonymous_class": true,
            "named_class": true
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "database"
    ]
}
